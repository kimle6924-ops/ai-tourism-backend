# Docker database service (used by docker-compose)
DB_PASSWORD=your_password
DB_ROOT_PASSWORD=your_root_password

# Application database connection (local run, MySQL)
DATABASE_URL=Server=localhost;Port=3306;Database=ai_tourism;User=app;Password=your_password;CharSet=utf8mb4

# JWT
JWT__SECRET=your-secret-key-at-least-32-characters-long
JWT__ISSUER=AITourism
JWT__AUDIENCE=AITourism
JWT__EXPIRATIONINMINUTES=60

# Cloudinary
CLOUDINARY__CLOUDNAME=
CLOUDINARY__APIKEY=
CLOUDINARY__APISECRET=
CLOUDINARY__FOLDER=ai-tourism

# Gemini
GEMINI__APIKEY=
GEMINI__MODEL=gemini-3-flash-preview
GEMINI__FALLBACKMODELSCSV=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-flash,gemini-1.5-pro

# Security
SECURITY__ALLOWPLAINTEXTPASSWORD=false
SECURITY__ENVIRONMENTMODE=Production

# Vietnam Provinces API (v2 post-2025 merger)
PROVINCES_API__BASEURL=https://provinces.open-api.vn/api/v2

# CORS
CORS__ALLOWEDORIGINS=http://localhost:3000
